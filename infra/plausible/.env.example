# Self-hosted Plausible — environment variables.
#
# Copy this file to `.env` (same directory) before running
# `docker compose up`. Every value with `CHANGE_ME` MUST be
# replaced before the stack will boot cleanly.
#
# Reference: https://github.com/plausible/community-edition/wiki/configuration

# ─── Hostname + URL ──────────────────────────────────────────────
# Public URL Plausible knows itself by. Must match the Caddyfile
# host + the DNS record + the `ANALYTICS_SCRIPT` constant in
# `src/lib/analytics.ts`.
BASE_URL=https://stats.libre.academy

# ─── Cryptographic keys ──────────────────────────────────────────
# Phoenix session secret — generate with:
#   openssl rand -base64 48
# At least 64 chars of high-entropy randomness. Rotating this
# invalidates existing user sessions (forces re-login).
SECRET_KEY_BASE=CHANGE_ME_openssl_rand_base64_48

# Tokens / database fields are encrypted at rest using this. Same
# generator. Rotating WILL break existing tokens — keep stable.
TOTP_VAULT_KEY=CHANGE_ME_openssl_rand_base64_32

# ─── Database connections ────────────────────────────────────────
# Postgres password — used by both the postgres service AND the
# Plausible app's DATABASE_URL below.
POSTGRES_PASSWORD=CHANGE_ME_strong_password

# Connection strings. The hostnames here match the docker-compose
# service names — don't change them unless you also rename the
# services.
DATABASE_URL=postgres://postgres:${POSTGRES_PASSWORD}@plausible_db:5432/plausible_db
CLICKHOUSE_DATABASE_URL=http://plausible_events_db:8123/plausible_events_db

# ─── Mailer ──────────────────────────────────────────────────────
# Plausible sends invite + password-reset emails. Pick a provider:
#   - SMTP (Mailgun / Postmark / SES / etc.)
#   - Local sendmail (not recommended in prod)
# When unconfigured, account-recovery flows break. The first-user
# bootstrap below still works without mail because we register
# directly via the open-signup page.
MAILER_EMAIL=hello@libre.academy
SMTP_HOST_ADDR=smtp.yourprovider.com
SMTP_HOST_PORT=587
SMTP_USER_NAME=postmaster@libre.academy
SMTP_USER_PWD=CHANGE_ME_smtp_password

# ─── Admin bootstrap (one-time) ──────────────────────────────────
# On first boot, Plausible's signup page is OPEN — register the
# admin account immediately. After that, set DISABLE_REGISTRATION=
# true and `docker compose up -d` to lock the form so randos
# can't create accounts on your instance.
DISABLE_REGISTRATION=false

# ─── Optional ────────────────────────────────────────────────────
# Limit dashboards a non-admin user can manage. Default unlimited.
# MAX_BUILD_SITES=10

# Skip the funnels-feature experimental flag.
# ENABLE_EMAIL_VERIFICATION=false
