<!--
  ClickHouse user-profile overrides for Plausible. Disables the
  same set of verbose query / thread logs at the profile level
  so user queries don't re-enable what config.xml turned off.
-->
<clickhouse>
    <profiles>
        <default>
            <log_queries>0</log_queries>
            <log_query_threads>0</log_query_threads>
        </default>
    </profiles>
</clickhouse>
