  "template": "\nconst std = @import(\"std\");\n\npub fn wordCounts(alloc: std.mem.Allocator, text: []const u8) !std.StringHashMap(u32) {\n    var map: std.StringHashMap(u32) = .init(alloc);\n    errdefer {\n        var it = map.iterator();\n        while (it.next()) |entry| alloc.free(entry.key_ptr.*);\n        map.deinit();\n    }\n    var iter = std.mem.__SLOT_tokenize__(u8, text, ' ');\n    while (iter.next()) |word| {\n        const lower = try alloc.__SLOT_dupe__(u8, word);\n        for (lower) |*c| c.* = std.ascii.__SLOT_toLower__(c.*);\n        const r = try map.__SLOT_getOrPut__(lower);\n        if (r.found_existing) {\n            alloc.free(lower);          // we already have this key — free the new copy\n            r.value_ptr.* __SLOT_incr__ 1;\n        } else {\n            r.value_ptr.* = __SLOT_init__;\n        }\n    }\n    return map;\n}\n\n",
