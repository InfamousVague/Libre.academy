  "template": "\nconst std = @import(\"std\");\n\npub const BasicStats = struct {\n    chars: u32,\n    words: u32,\n    lines: u32,\n};\n\npub fn countBasic(text: []const u8) BasicStats {\n    if (text.len == 0) return .{ .chars = 0, .words = 0, .lines = 0 };\n    var words: u32 = 0;\n    var iter = std.mem.__SLOT_tokenize_fn__(u8, text, __SLOT_delims__);\n    while (iter.next()) |_| {\n        words += 1;\n    }\n    var lines: u32 = __SLOT_init_lines__;\n    for (text) |c| {\n        if (c == __SLOT_newline__) lines += 1;\n    }\n    return .{\n        .chars = @intCast(text.len),\n        .words = words,\n        .lines = lines,\n    };\n}\n\n",
