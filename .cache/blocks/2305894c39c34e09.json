  "template": "\nconst std = @import(\"std\");\n\npub fn wordFrequency(alloc: std.mem.Allocator, text: []const u8) !std.StringHashMap(u32) {\n    var map: std.StringHashMap(u32) = .init(alloc);\n    errdefer map.deinit();\n\n    var iter = std.mem.__SLOT_tokenize__(u8, text, ' ');\n    while (iter.next()) |word| {\n        const r = try map.__SLOT_method__(word);\n        if (r.__SLOT_check__) {\n            r.value_ptr.* += __SLOT_inc__;\n        } else {\n            r.value_ptr.* = __SLOT_init__;\n        }\n    }\n    return map;\n}\n",
