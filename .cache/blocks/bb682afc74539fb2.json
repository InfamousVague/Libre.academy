  "template": "\nconst std = @import(\"std\");\n\npub const TokenKind = enum {\n    number,\n    identifier,\n    plus,\n    minus,\n    star,\n    slash,\n    other,\n};\n\nfn isDigit(c: u8) bool { return c >= '0' and c <= '9'; }\nfn isAlpha(c: u8) bool { return (c >= 'a' and c <= 'z') or (c >= 'A' and c <= 'Z'); }\n\npub fn classify(s: []const u8) TokenKind {\n    if (s.len == 0) return .other;\n    if (__SLOT_len_check__) {\n        switch (s[0]) {\n            '+' => return __SLOT_plus_token__,\n            '-' => return .minus,\n            '*' => return .star,\n            '/' => return .slash,\n            else => {},\n        }\n    }\n    if (__SLOT_alpha_check__) return .identifier;\n    if (isDigit(s[0])) {\n        for (s) |c| {\n            if (!isDigit(c)) return __SLOT_invalid_number__;\n        }\n        return __SLOT_valid_number__;\n    }\n    return .other;\n}\n",
