# Dependencies
node_modules/
ingest/node_modules/

# Build output
dist/
dist-web/
src-tauri/target/
src-tauri/gen/
# ...except the iOS Info.plist, which we hand-edit to register the
# `fishbones://` URL scheme for OAuth callbacks (see
# `CFBundleURLTypes` block in the file). `tauri ios init` would
# clobber this edit, but routine `tauri ios build` runs leave it
# alone — so we track the file. After any future `tauri ios init`,
# re-apply the URL-scheme block before building or sign-in
# callbacks dead-end in Safari.
!src-tauri/gen/apple/fishbones_iOS/Info.plist
# Build cache for the vendor + node-fetch scripts. Both populate from
# package metadata at build time; nothing here is hand-authored.
src-tauri/.cache/
# Bundled Node 22 runtime — fetched fresh by scripts/fetch-node-runtime.mjs
# during `npm run build`. ~186MB, host-platform-specific, not portable.
src-tauri/resources/node/
# Rust target dir for the API server. Same reasoning as src-tauri/target.
api/target/

# Web build vendor staging — copied from src-tauri/resources/vendor
# by scripts/copy-vendor-to-public.mjs as part of `npm run build:web`.
public/vendor/
# Starter-course staging — extracted from src-tauri/resources/bundled-packs
# by scripts/extract-starter-courses.mjs as part of `npm run build:web`.
# We ignore the contents but NOT the directory itself, so per-file
# negation rules below can re-include specific committed sidecars.
public/starter-courses/*
# Exception: HelloTrade isn't a .fishbones archive — it's a sidecar JSON
# generated by `scripts/hellotrade/generate-course.py`, not by the
# extract pipeline. We commit it (plus the cover) so the marketing
# site's CI build picks it up without running python; the file's
# stable enough that committing it is fine. Update by re-running the
# python script + magick the cover-overrides PNG, then commit both.
!public/starter-courses/hellotrade.json
!public/starter-courses/hellotrade.jpg
# Guided-tour narration MP3s — synthesised from
# src/components/Tour/tourSteps.json by scripts/generate-tour-audio.mjs
# (`make tour-audio`). MP3 binaries + the manifest the runtime fetches
# from /tour-audio/manifest.json. Regenerated locally; tour audio is
# silent until you run the script. The visual tour works either way.
public/tour-audio/

# macOS
.DS_Store

# Editor
.vscode/
.idea/

# Env / secrets
.env
.env.*
!.env.example


# Misc
*.log
test-results/
playwright-report/
# `make run` device-picker cache (per-developer choice of sim/device)
.fishbones-devices.cache

# TS incremental build outputs
*.tsbuildinfo
# Compiled vite config (tsc by-product when running --noEmit on .ts file)
vite.config.d.ts
vite.config.js

# LLM micropuzzle authoring cache (one entry per lesson, sha-keyed)
.cache/micropuzzles/

# LLM blocks-data authoring cache (one entry per exercise, sha-keyed)
.cache/blocks/