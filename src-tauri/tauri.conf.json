{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Fishbones",
  "version": "0.1.0",
  "identifier": "com.mattssoftware.kata",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npx vite build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Fishbones",
        "width": 1180,
        "height": 780,
        "resizable": true,
        "center": true,
        "minWidth": 900,
        "minHeight": 600,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "trafficLightPosition": { "x": 18, "y": 23 }
      }
    ],
    "security": {
      "csp": "default-src 'self' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'wasm-unsafe-eval' https://cdn.jsdelivr.net; connect-src 'self' https://cdn.jsdelivr.net https://play.rust-lang.org https://play.golang.org; font-src 'self' https://cdn.jsdelivr.net data:;"
    }
  },
  "plugins": {},
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/bundled-packs/*"],
    "macOS": {
      "frameworks": [],
      "exceptionDomain": null,
      "entitlements": "Entitlements.plist",
      "signingIdentity": "0948896DC970503ADEF5B5070E0BB3E9D9047757"
    }
  }
}
