{
  "name": "libre",
  "displayName": "Libre.academy",
  "description": "Take Libre.academy courses inside VSCode. Pairs with the Libre desktop app — pick a lesson there, work through it here.",
  "version": "0.1.0",
  "publisher": "libre-academy",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/libre-academy/libre"
  },
  "homepage": "https://libre.academy",
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Education"
  ],
  "keywords": [
    "libre",
    "academy",
    "tutorial",
    "exercises",
    "rust",
    "typescript",
    "python"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onUri"
  ],
  "contributes": {
    "commands": [
      {
        "command": "libre.openLesson",
        "title": "Libre: Open Lesson…",
        "category": "Libre"
      },
      {
        "command": "libre.runTests",
        "title": "Libre: Run Tests",
        "category": "Libre",
        "icon": "$(play)"
      },
      {
        "command": "libre.markComplete",
        "title": "Libre: Mark Lesson Complete",
        "category": "Libre",
        "icon": "$(check)"
      },
      {
        "command": "libre.nextLesson",
        "title": "Libre: Next Lesson",
        "category": "Libre",
        "icon": "$(arrow-right)"
      },
      {
        "command": "libre.revealSolution",
        "title": "Libre: Reveal Solution",
        "category": "Libre"
      },
      {
        "command": "libre.showHint",
        "title": "Libre: Show Next Hint",
        "category": "Libre"
      },
      {
        "command": "libre.refreshOutline",
        "title": "Libre: Refresh Course Outline",
        "category": "Libre",
        "icon": "$(refresh)"
      }
    ],
    "views": {
      "libre-sidebar": [
        {
          "id": "libre.outline",
          "name": "Course Outline",
          "icon": "media/icon.png",
          "contextualTitle": "Libre"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "libre-sidebar",
          "title": "Libre",
          "icon": "media/icon.png"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "libre.refreshOutline",
          "when": "view == libre.outline",
          "group": "navigation"
        }
      ],
      "editor/title": [
        {
          "command": "libre.runTests",
          "when": "libre.currentLessonIsExercise",
          "group": "navigation@1"
        },
        {
          "command": "libre.markComplete",
          "when": "libre.currentLessonIsReading",
          "group": "navigation@2"
        },
        {
          "command": "libre.nextLesson",
          "when": "libre.currentLessonId",
          "group": "navigation@3"
        }
      ]
    },
    "configuration": {
      "title": "Libre",
      "properties": {
        "libre.coursesDir": {
          "type": "string",
          "default": "",
          "description": "Override the path to the Libre courses directory. Default is the platform-specific Libre data dir (~/Library/Application Support/com.mattssoftware.libre on macOS)."
        },
        "libre.progressDb": {
          "type": "string",
          "default": "",
          "description": "Override the path to the shared progress.sqlite. Default sits next to the courses dir."
        }
      }
    },
    "keybindings": [
      {
        "command": "libre.runTests",
        "key": "ctrl+shift+enter",
        "mac": "cmd+shift+enter",
        "when": "libre.currentLessonIsExercise"
      },
      {
        "command": "libre.nextLesson",
        "key": "ctrl+shift+right",
        "mac": "cmd+shift+right",
        "when": "libre.currentLessonId"
      }
    ]
  },
  "scripts": {
    "//build": "Marks node-sqlite3-wasm external so the bundler doesn't try to inline its wasm asset; vsce will ship the package's node_modules so the wasm file is available at runtime.",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --external:node-sqlite3-wasm --format=cjs --platform=node --target=node18",
    "watch": "npm run build -- --watch --sourcemap",
    "package": "npm run build -- --minify && vsce package",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "markdown-it": "^14.1.0",
    "node-sqlite3-wasm": "^0.8.57"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^3.1.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.3"
  }
}
