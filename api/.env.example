# Libre API — environment-driven config.
#
# Copy this file to `.env` and fill in the values. Missing values
# disable the corresponding sign-in route — main.rs logs which ones
# are unset on startup so a half-configured deploy surfaces a 503
# from the OAuth endpoints rather than silently letting tokens
# through with `aud: ""` matching nothing.

# ── Sign in with Apple ────────────────────────────────────────────
# Service ID — the audience claim Apple stamps on every id_token.
# Configure under Certificates → Identifiers → Services IDs in the
# Apple Developer portal. Bundle ids work too if you wired Apple
# Sign-In as a capability instead of a service.
APPLE_CLIENT_ID=com.mattssoftware.libre.signin

# Apple Team ID (10-char alphanum, e.g. F6ZAL7ANAD). Used as the
# `iss` claim of the per-request client_secret JWT we sign for the
# browser-OAuth code-exchange step.
APPLE_TEAM_ID=

# Apple Key ID — the identifier of the .p8 you downloaded from the
# developer portal. Goes into the JWT `kid` header.
APPLE_KEY_ID=

# Contents of the .p8 private key file (PEM-encoded). Either provide
# inline via APPLE_PRIVATE_KEY_PEM (handy for ephemeral container
# deploys) or via APPLE_PRIVATE_KEY_FILE pointing at a path on disk
# (production deploys with bind-mounted secrets).
APPLE_PRIVATE_KEY_PEM=
APPLE_PRIVATE_KEY_FILE=

# Path to the apple-developer-domain-association.txt that Apple's
# portal hands you. Served at /.well-known/...; the file's read on
# every request so dropping in a new copy via scp takes effect
# without restarting the API.
APPLE_DOMAIN_ASSOCIATION_FILE=/etc/libre-api/apple-domain-association.txt

# ── Sign in with Google ───────────────────────────────────────────
# OAuth client id (web client or iOS client — whichever the desktop
# build uses). Created in Google Cloud Console → APIs & Services →
# Credentials.
GOOGLE_CLIENT_ID=

# OAuth client secret. Required only for the browser-OAuth path
# (PKCE + secret) on /auth/google/callback. The pure native-token
# path (POST /auth/google with an id_token in the body) doesn't
# need it.
GOOGLE_CLIENT_SECRET=

# ── Server config ─────────────────────────────────────────────────
# Public URL of THIS API server (e.g. https://api.mattssoftware.com).
# Used to build provider redirect_uris plus the success deep-link
# template — must be the exact value registered with Google + Apple
# or they'll reject the auth request.
PUBLIC_URL=https://api.mattssoftware.com

# SQLite file path. Default works for a systemd-managed deploy with
# /var/lib/libre-api owned by the service user.
DATABASE_PATH=/var/lib/libre-api/api.sqlite

# Bind address. We listen on 127.0.0.1 because Caddy (the public
# TLS terminator) lives on the same host.
HOST=127.0.0.1
PORT=9443
